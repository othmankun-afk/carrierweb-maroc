# URL of your WPGraphQL endpoint. Leave unset (or comment out) to run the
# site fully on the local mock data in lib/mock-data.ts — useful before WP
# is set up, or as an offline/dev fallback.
#
# Local WP (LocalWP/Docker):
# WORDPRESS_API_URL=http://carrierwebmaroc.local/graphql
#
# Production WP:
# WORDPRESS_API_URL=https://cms.carrierwebmaroc.com/graphql
WORDPRESS_API_URL=http://your-site.local/graphql

# Jeton de vérification Google Search Console (méthode « balise HTML »).
# Search Console > Ajouter une propriété > Préfixe d'URL > balise HTML :
# copier uniquement la valeur de l'attribut content="..." ci-dessous.
# Une fois le site vérifié, soumettre le sitemap : Indexation > Sitemaps >
# https://www.carrierweb.ma/sitemap.xml
# GOOGLE_SITE_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────
# Formulaire de contact (envoi d'e-mail via SMTP / Nodemailer)
#
# Si ces variables ne sont pas renseignées, le formulaire bascule
# automatiquement sur l'ouverture du client e-mail local (mailto:).
#
# Exemple avec Gmail : activer la validation en 2 étapes sur le compte,
# puis créer un « mot de passe d'application » (Google > Sécurité >
# Mots de passe des applications) et le coller dans SMTP_PASS.
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587            # 587 (STARTTLS) ou 465 (SSL)
# SMTP_SECURE=false        # true si port 465
# SMTP_USER=votre-adresse@gmail.com
# SMTP_PASS=xxxxxxxxxxxxxxxx   # mot de passe d'application (16 caractères)
#
# Destinataire des demandes (défaut : o68218758@gmail.com)
# CONTACT_EMAIL_TO=o68218758@gmail.com
# Expéditeur affiché (défaut : SMTP_USER)
# CONTACT_EMAIL_FROM=votre-adresse@gmail.com